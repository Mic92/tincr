config phantun-client 'config'
	option enabled '0'

	# Local IP:port to listen for incoming UDP datagrams
	option local_addr '127.0.0.1:1234'

	# Remote address:port where Phantun Server is listening
	option remote_addr ''

	# TUN interface name (auto-selected if empty)
	option tun_name ''

	# TUN interface local IPv4 address
	option tun_local '192.168.200.1'

	# TUN interface peer IPv4 address
	option tun_peer '192.168.200.2'

	# TUN interface local IPv6 address
	option tun_local6 'fcc8::1'

	# TUN interface peer IPv6 address
	option tun_peer6 'fcc8::2'

	# Only use IPv4 when connecting to remote
	option ipv4_only '0'

	# File whose content is sent as first data packet after TCP handshake
	option handshake_packet ''
